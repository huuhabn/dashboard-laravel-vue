APP_NAME="Laravel dashboard vue"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# When the Vue dev server runs on another port, set this to APP_URL so /storage/... avatars resolve correctly.
# VITE_BACKEND_URL=http://127.0.0.1:8000

# Vue SPA: dashboard and settings routes use /{DASHBOARD_PREFIX}/... (no slashes in value).
DASHBOARD_PREFIX=admin

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Auth (see config/services.php): password_only | otp_only | both
SAAS_AUTH_LOGIN_METHODS=both
# When OTP is enabled: email | phone | both
SAAS_AUTH_OTP_DELIVER_TO=email
# ISO 3166-1 alpha-2 default for parsing national phone numbers (profile, register, OTP)
SAAS_DEFAULT_PHONE_REGION=VN

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Avatar uploads: "public" (local storage + /storage URL) or "s3" (AWS S3 / Cloudflare R2).
# For R2/S3, set FILESYSTEM_AVATAR_DISK=s3 and AWS_* below; bucket/CDN must allow anonymous GET so the browser can show <img> previews.
FILESYSTEM_AVATAR_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
# Public base URL for objects (custom domain or bucket website). Required for avatar URLs in JSON.
AWS_URL=
# R2: https://<accountid>.r2.cloudflarestorage.com — set AWS_USE_PATH_STYLE_ENDPOINT=true
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Optional key prefix (e.g. storage). Must match config/filesystems.php s3 `root`.
AWS_ROOT=

VITE_APP_NAME="${APP_NAME}"

# OAuth (optional). Redirect URIs must match provider console: {APP_URL}/auth/google/callback, {APP_URL}/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
